<!DOCTYPE html>
<html>

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
        <a href="/" class="text-blue-500 mt-2 hover:underline inline-block">Back to Home</a>
        <form action="/edit" method="post" class="mt-5">
            <input class="block w1/4 rounded-md outline-none px-5 py-2 bg-zinc-800" type="text"
                placeholder="previous name" name="previous" value="<%= title %>" readonly>
            <input class="block w1/4 rounded-md  mt-3 outline-none px-5 py-2 bg-zinc-800" type="text"
                placeholder="new name" name="new">
            <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type="submit" value="Update Name">
        </form>
    </div>
</body>

</html>