<!DOCTYPE html>
<html>

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Page Title</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white container center">
            <form action="/create" method="post">
                <input class="block w-2/4 rounded-md outline-none px-5 py-2 bg-zinc-800 " type="text"
                    placeholder="Enter Title" name="title" required>
                <textarea class="block mt-2 w-2/4 rounded-md outline-none px-5 py-2 resize-none bg-zinc-800"
                    placeholder="Write Detail" name="detail"></textarea>
                <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Submit">
            </form>
        </div>
        <div class="tasks flex flex-wrap gap-3 p-10">
            <% if(files.length>0){ %>
                <% files.forEach(function(file) { %>
                    <div class="task w-72 px-3 py-1 rounded-md bg-zinc-800">
                        <h1 class="text-white text-3xl tracking-tighter">
                            <%= file.replace('.txt', '' ).split(" ").slice(0,3).join(" ")  %>
                        </h1>
                        <div class=" mt-1 flex justify-between items-center">
                            <a class="text-blue-500 hover:underline inline-block" href="/file/<%= file %>">Read
                                More</a>
                            <div class="flex gap-3">
                                <a class="text-yellow-500 hover:underline inline-block"
                                    href="/edit/<%= file %>">Edit</a>
                                <a href="/delete/<%= file %>" class="text-red-500 hover:underline inline-block"
                                    onclick="return confirm('Are you sure you want to delete this file?');">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                    <% })%>
                        <% }else{ %>
                            <h3 class="text-zinc-600">No tasks yet.</h3>
                            <% } %>

                                <!-- <div class="task w-72 hidden px-3 py-4 rounded-md bg-zinc-800">
                                    <h1 class="text-white text-3xl tracking-tighter">some task gose here </h1>
                                    <a class="text-blue-500 hover:underline inline-block mt-3" href="">Read More</a>
                                </div>
                                <div class="task w-72 hidden px-3 py-4 rounded-md bg-zinc-800">
                                    <h1 class="text-white text-3xl tracking-tighter">some task gose here </h1>
                                    <a class="text-blue-500 hover:underline inline-block mt-3" href="">Read More</a>
                                </div> -->

        </div>
    </div>
</body>

</html>